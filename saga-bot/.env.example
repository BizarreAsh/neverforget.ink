# ── Telegram ──────────────────────────────────────────────────────────────────
# 1. Создай бота: https://t.me/BotFather → /newbot
# 2. Скопируй токен сюда
TELEGRAM_TOKEN=1234567890:ABCDEFGHijklmnopQRSTUVWXYZ

# Куда слать уведомления:
#   • Личный чат — свой ID (@userinfobot в Telegram скажет)
#   • Группа/канал — добавь бота как admin, используй -100XXXXXXXXXX
CHAT_ID=your_chat_or_channel_id

# ── Ссылка ────────────────────────────────────────────────────────────────────
# Открой страницу с SAGA-квартирами в браузере, скопируй полный URL
# Например: https://tenant.immomio.com/de/applicants/items или любая страница
# со списком квартир (с фильтрами, если нужно)
TARGET_URL=https://tenant.immomio.com/de

# ── Интервал ──────────────────────────────────────────────────────────────────
# Как часто проверять (минуты). SAGA обновляет редко — 5 мин нормально.
CHECK_INTERVAL_MINUTES=5
